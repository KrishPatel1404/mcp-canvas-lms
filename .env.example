# Required: Canvas API credentials
CANVAS_API_TOKEN=your_canvas_api_token_here
CANVAS_DOMAIN=your_domain.instructure.com

# Optional: Logging level (debug | info | warn | error)
LOG_LEVEL=info

# Optional: Request resilience
CANVAS_MAX_RETRIES=3
CANVAS_RETRY_DELAY=1000
CANVAS_TIMEOUT=30000

# Optional: Transport — stdio (default) or streamable-http
MCP_TRANSPORT=stdio

# Only relevant when MCP_TRANSPORT=streamable-http
MCP_HTTP_HOST=127.0.0.1
MCP_HTTP_PORT=3000
MCP_HTTP_PATH=/mcp
MCP_HTTP_STATEFUL=true
MCP_HTTP_JSON_RESPONSE=true
# Comma-separated origin allowlist. Empty = allow all.
MCP_HTTP_ALLOWED_ORIGINS=

